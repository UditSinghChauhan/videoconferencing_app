PORT=8000
NODE_ENV=development
MONGODB_URI=your_mongodb_connection_string
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
JWT_SECRET=replace_with_a_secure_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_secure_random_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_COOKIE_MAX_AGE_MS=604800000
LOG_LEVEL=info

# PRODUCTION SETTINGS (for Render or similar)
# Change NODE_ENV to: production
# Change CORS_ORIGIN to: https://your-frontend-url.onrender.com
# Use secure, different JWT_SECRET values (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")

